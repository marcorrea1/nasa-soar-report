    "react-dom": "18.3.1",
    "react-router": "7.13.0",
    "tw-animate-css": "1.3.8",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.12",
    "@vitejs/plugin-react": "4.7.0",
    "concurrently": "^9.0.0",
